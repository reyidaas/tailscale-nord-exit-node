# Copy to .env and fill in. Do not commit .env.

# Container identity in your tailnet.
TS_HOSTNAME=nord-exit-node

# Generate a reusable/pre-authorized Tailscale auth key:
# https://login.tailscale.com/admin/settings/keys
# Recommended: tag it, then add --advertise-tags=tag:exit-node to TS_EXTRA_ARGS.
TS_AUTHKEY=
TS_EXTRA_ARGS=--advertise-exit-node --accept-dns=false

# Gluetun/NordVPN
VPN_SERVICE_PROVIDER=nordvpn

# Preferred: wireguard. Alternative: openvpn.
VPN_TYPE=wireguard

# Pick one or more of these location filters. Leave blank to let Gluetun choose.
SERVER_COUNTRIES=
SERVER_REGIONS=
SERVER_CITIES=
SERVER_HOSTNAMES=

# WireGuard/NordLynx mode.
# Get this from Nord manual WireGuard/NordLynx config tooling.
WIREGUARD_PRIVATE_KEY=
# Nord often works without explicitly setting addresses; if required, set it here.
WIREGUARD_ADDRESSES=

# OpenVPN mode only. Use Nord manual/service credentials, not normal account login.
OPENVPN_USER=
OPENVPN_PASSWORD=

# Optional: LAN subnets allowed to bypass the VPN from inside the container.
# Example: FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
# Do NOT add 100.64.0.0/10 here.
FIREWALL_OUTBOUND_SUBNETS=

TZ=UTC
GLUETUN_TAG=latest
TAILSCALE_TAG=latest
ROUTE_FIX_INTERVAL=30
